<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/hostPortInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/host_port_hint"
            android:inputType="textUri"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textColorHint="#808080" />

        <Button
            android:id="@+id/connectButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connect" />
    </LinearLayout>

    <ImageView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:background="#000000"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="4dp"
        android:textColor="#FFFFFF"
        android:text="@string/status_disconnected" />

    <!-- Raw demo: one row of hold-to-press buttons, not a proper GBA-style
         layout (no D-pad shape, no overlay-on-video). Good enough to prove
         the transport/protocol/codec pipeline end-to-end; a real touch
         layout is future work, see clients/android/README.md. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10">

        <Button android:id="@+id/btnUp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Up" />
        <Button android:id="@+id/btnDown" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Down" />
        <Button android:id="@+id/btnLeft" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Left" />
        <Button android:id="@+id/btnRight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Right" />
        <Button android:id="@+id/btnSelect" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Select" />
        <Button android:id="@+id/btnStart" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Start" />
        <Button android:id="@+id/btnL" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="L" />
        <Button android:id="@+id/btnR" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="R" />
        <Button android:id="@+id/btnB" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="B" />
        <Button android:id="@+id/btnA" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="A" />
    </LinearLayout>
</LinearLayout>
