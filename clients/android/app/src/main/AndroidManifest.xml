<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- No android:usesCleartextTraffic needed: the connection is a raw NDK
         POSIX socket (see cpp/jni_bridge.c), not java.net/HttpURLConnection,
         so Android's Network Security Config cleartext restriction (which
         only hooks the Java networking stack) doesn't apply to it. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
